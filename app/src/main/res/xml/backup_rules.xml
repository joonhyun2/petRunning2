<full-backup-content>
    <!-- Room DB는 기기별 로컬 데이터이므로 백업에서 제외 -->
    <exclude domain="database" path="petrunning.db"/>
    <exclude domain="database" path="petrunning.db-shm"/>
    <exclude domain="database" path="petrunning.db-wal"/>
</full-backup-content>